# Python cache (Streamlit generates some on first run, exclude for clean deployment)
__pycache__/
*.py[cod]
*$py.class

# Virtual environments (should not be committed anyway)
venv/
ENV/
.venv/

# IDE settings
.vscode/
.idea/
*.swp
*.swo
*~

# Streamlit generated files (not part of deployment)
.streamlit/
static/
cache/

# Log files
*.log
logs/

# Temporary or backup files
*.bak
*.tmp
*.pyc
.env  # Local environment file - use GitHub Secrets instead

# Data directory placeholder (actual data files are auto-generated by workflow)
!.data/.gitkeep
.data/*.json  # Exclude actual JSON data for minimal production repo
